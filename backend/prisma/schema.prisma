generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id         String   @id @default(cuid())
  text       String   @unique
  options    Json
  answer     String
  difficulty String
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Certificate {
  id            String   @id @default(cuid())
  playerName    String
  roomCode      String
  score         Int
  grade         String
  verification  String   @unique
  createdAt     DateTime @default(now())
}
